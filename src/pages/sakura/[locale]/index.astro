---
/**
 * 新版首页 —— /sakura/{zh,en,ja,ko}/
 *
 * 策略：直接复用旧版 /zh/index.mdx 用到的那几个组件，
 * 由 html.sakura 下的 sakura-theme.css + sakura-components.css
 * 把它们换皮。文案继续来自 i18n，不增不减。
 *
 * 跳过的组件（由 SakuraLayout 自己提供）：
 *   - SplashNav（SakuraLayout 里已有 sakura 版）
 *   - EmergencyBanner（同上）
 *   - SiteFooter（同上）
 *   - ParticleBackground / ParticleCanvas（新版用 CarnivalBg）
 */
import { getEntry } from 'astro:content';
import SakuraLayout from '../../../layouts/SakuraLayout.astro';
import { t, type Locale } from '../../../i18n/ui';

// 复用旧版真正的组件
import HeroSection from '../../../components/layout/HeroSection.astro';
import ActionCards from '../../../components/layout/ActionCards.astro';
import GuideScenarioStrip from '../../../components/layout/GuideScenarioStrip.astro';
import DrugQuickNav from '../../../components/layout/DrugQuickNav.astro';
import MissionStatement from '../../../components/layout/MissionStatement.astro';

export function getStaticPaths() {
  return [
    { params: { locale: 'zh' } },
    { params: { locale: 'en' } },
    { params: { locale: 'ja' } },
    { params: { locale: 'ko' } },
  ];
}

const { locale } = Astro.params;
const loc = (locale && locale in { zh: 1, en: 1, ja: 1, ko: 1 } ? locale : 'zh') as Locale;

// index frontmatter（拿 description 用于 <meta>）
const indexEntry = await getEntry('docs', `${loc}/index`);
const pageTitle = indexEntry?.data?.title ?? t(loc, 'hero.title');
const pageDescription = indexEntry?.data?.description ?? '';
---

<SakuraLayout title={pageTitle} description={pageDescription} locale={loc}>
  <HeroSection />
  <ActionCards />
  <GuideScenarioStrip />
  <DrugQuickNav />

  <!-- 快速工具条（和旧版 /zh/index.mdx 里的 quick-tools 块一致） -->
  <div class="quick-tools">
    <div class="quick-tools__inner">
      <div class="quick-tools__stats">
        {loc === 'zh' && (<>覆盖 <strong>20 种药物</strong> · <strong>25 家</strong>友好医院 · 全部引用标注 DOI</>)}
        {loc === 'en' && (<>Covering <strong>20 medications</strong> · <strong>25</strong> friendly clinics · Every claim cites a DOI</>)}
        {loc === 'ja' && (<><strong>20種の薬剤</strong> · <strong>25の</strong>医療機関 · すべての引用にDOI付き</>)}
        {loc === 'ko' && (<><strong>20가지 약물</strong> · <strong>25곳</strong>의료기관 · 모든 인용에 DOI 포함</>)}
      </div>
      <div class="quick-tools__links">
        <a href={`/sakura/${loc}/tools/blood-checker/`} class="quick-tools__link">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6"/><path d="M9 15l2 2 4-4"/></svg>
          {loc === 'zh' && '血检自查'}
          {loc === 'en' && 'Blood Test Check'}
          {loc === 'ja' && '血液検査チェック'}
          {loc === 'ko' && '혈액 검사 확인'}
        </a>
        <a href={`/sakura/${loc}/tools/dose-simulator/`} class="quick-tools__link">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
          {loc === 'zh' && '剂量模拟器'}
          {loc === 'en' && 'Dose Simulator'}
          {loc === 'ja' && '用量シミュレータ'}
          {loc === 'ko' && '용량 시뮬레이터'}
        </a>
        <a href={`/sakura/${loc}/tools/risk-screener/`} class="quick-tools__link">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          {loc === 'zh' && '风险自查'}
          {loc === 'en' && 'Risk Screener'}
          {loc === 'ja' && 'リスクチェック'}
          {loc === 'ko' && '위험 자가진단'}
        </a>
      </div>
    </div>
  </div>

  <MissionStatement />
</SakuraLayout>

<style is:global>
  /* quick-tools 条，和旧版用同一套 class，sakura CSS 会接管外观 */
  .quick-tools {
    margin: 24px auto;
    max-width: 1100px;
  }
  .quick-tools__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    padding: 16px 22px;
    flex-wrap: wrap;
  }
  .quick-tools__stats {
    font-size: 14px;
    color: var(--fg-1, #4A2838);
  }
  .quick-tools__stats strong {
    color: var(--sakura-pink-deep, #E5578B);
    font-weight: 700;
  }
  .quick-tools__links {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }
  .quick-tools__link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 8px 14px;
    font-size: 13px;
    font-weight: 700;
    color: var(--ink, #4A2838);
    background: var(--ivory, #FFFAF0);
    border: 2px solid var(--ink, #4A2838);
    border-radius: 999px;
    box-shadow: 2px 2px 0 var(--ink, #4A2838);
    text-decoration: none;
    transition: transform 0.15s, box-shadow 0.15s;
  }
  .quick-tools__link:hover {
    transform: translate(-1px, -1px);
    box-shadow: 3px 3px 0 var(--ink, #4A2838);
    background: var(--butter, #FFE89C);
  }
</style>
