---
/**
 * 新版首页 —— /sakura/{zh,en,ja,ko}/
 * 所有文字来源：
 * - Hero title/subtitle/slogan: src/i18n/ui.ts（和旧版 HeroSection 同源）
 * - 卡片 title/description: src/content/docs/{locale}/*.mdx 的 frontmatter
 * 不引入任何设计稿里的虚构品牌字
 */
import { getEntry } from 'astro:content';
import SakuraLayout from '../../../layouts/SakuraLayout.astro';
import InkCard from '../../../components/sakura/InkCard.astro';
import HibiscusMark from '../../../components/sakura/HibiscusMark.astro';
import { t, type Locale } from '../../../i18n/ui';

export function getStaticPaths() {
  return [
    { params: { locale: 'zh' } },
    { params: { locale: 'en' } },
    { params: { locale: 'ja' } },
    { params: { locale: 'ko' } },
  ];
}

const { locale } = Astro.params;
const loc = (locale && locale in { zh: 1, en: 1, ja: 1, ko: 1 } ? locale : 'zh') as Locale;

// 从 content collection 读 index entry（拿 description）
const indexEntry = await getEntry('docs', `${loc}/index`);
const pageTitle = indexEntry?.data?.title ?? t(loc, 'hero.title');
const pageDescription = indexEntry?.data?.description ?? '';

// Hero 文本全部走 i18n（和旧版 HeroSection 一致）
const heroTitle = t(loc, 'hero.title');
const heroSubtitle = t(loc, 'hero.subtitle');
const heroSlogan = t(loc, 'hero.slogan');

// 主要入口卡片（从 content collection 真实数据读）
const cardSlugs = [
  { slug: 'before-you-start', variant: 'flame' as const },
  { slug: 'pathway',          variant: 'gold' as const },
  { slug: 'risks',            variant: 'pink' as const },
  { slug: 'dose-limits',      variant: 'mint' as const },
  { slug: 'blood-tests',      variant: 'sky' as const },
  { slug: 'china-reality',    variant: 'lavender' as const },
];

const cards = await Promise.all(cardSlugs.map(async (c) => {
  const entry = await getEntry('docs', `${loc}/${c.slug}`);
  return {
    ...c,
    title: entry?.data?.title ?? c.slug,
    description: entry?.data?.description ?? '',
    href: `/sakura/${loc}/${c.slug}/`,
  };
}));
---

<SakuraLayout title={pageTitle} description={pageDescription} locale={loc}>
  <section class="sakura-hero">
    <div class="sakura-hero__mark">
      <HibiscusMark size={96} />
    </div>

    <div class="sakura-hero__subtitle">{heroSubtitle}</div>

    <h1 class="sakura-hero__title">
      HRT<span class="gradient-flame">药典</span>
    </h1>

    <p class="sakura-hero__slogan">{heroSlogan}</p>

    <p class="sakura-hero__description">{pageDescription}</p>
  </section>

  <section class="sakura-grid">
    {cards.map((c) => (
      <InkCard variant={c.variant} href={c.href} class="sakura-card">
        <h3 class="sakura-card__title">{c.title}</h3>
        <p class="sakura-card__desc">{c.description}</p>
      </InkCard>
    ))}
  </section>
</SakuraLayout>

<style>
  .sakura-hero {
    text-align: center;
    padding: 32px 0 40px;
  }
  .sakura-hero__mark {
    display: inline-flex;
    margin-bottom: 8px;
  }
  .sakura-hero__subtitle {
    font-family: "Plus Jakarta Sans", "Noto Sans SC", sans-serif;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.25em;
    color: #E5578B;
    text-transform: uppercase;
    margin-bottom: 8px;
  }
  .sakura-hero__title {
    font-family: "Fraunces", "Noto Serif SC", serif;
    font-size: clamp(3.5rem, 9vw, 7rem);
    line-height: 1;
    margin: 0;
    color: #4A2838;
    font-weight: 400;
  }
  .sakura-hero__title::after { display: none; }
  .gradient-flame {
    background: linear-gradient(135deg, #E5578B, #FF8E7F 50%, #F5C842);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .sakura-hero__slogan {
    font-family: "Ma Shan Zheng", "Klee One", cursive;
    font-size: clamp(1.2rem, 2.6vw, 1.6rem);
    color: #E5578B;
    margin: 16px auto 8px;
  }
  .sakura-hero__description {
    font-family: "Noto Sans SC", sans-serif;
    font-size: 14px;
    line-height: 1.8;
    color: #7A5568;
    max-width: 680px;
    margin: 12px auto 0;
  }

  .sakura-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 20px;
    margin-top: 32px;
  }

  .sakura-card {
    min-height: 160px;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .sakura-card__title {
    font-family: "Noto Serif SC", "Klee One", serif;
    font-size: 1.2rem;
    font-weight: 700;
    margin: 0;
    line-height: 1.3;
  }
  .sakura-card__title::after { display: none; }
  .sakura-card__desc {
    font-family: "Noto Sans SC", sans-serif;
    font-size: 13px;
    line-height: 1.65;
    margin: 0;
    opacity: 0.88;
  }
</style>
