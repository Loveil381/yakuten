---
/**
 * SakuraHint — 首次访问引导卡片（中文站点专用）
 *
 * 显示条件（必须全部满足）：
 *  1. localStorage 无 `sakura-hint-dismissed-v1` 标记
 *  2. localStorage 无 `sakura-theme=on`（已是 sakura 用户不再打扰）
 *  3. 仅 zh 路径渲染（layout 层判断）
 *
 * 关闭机制：
 *  - 「体验」按钮 → 派发 sakura-hint:activate（ThemeToggle 监听）+ 写 dismissed-v1
 *  - 「稍后」按钮 / 点击外部 / Esc → 写 dismissed-v1
 *  - 30 秒自动淡出（不写 dismissed，下次还能看到）
 *
 * 视觉：
 *  - dark 模式米哈游玻璃 morphism + 樱粉边线
 *  - sakura 模式下不显示（已是 sakura 用户）
 *  - prefers-reduced-motion 静态显隐
 */
---

<style is:global>
  .sakura-hint {
    position: fixed;
    bottom: 80px; /* ThemeToggle 上方 */
    left: 24px;
    z-index: 9998; /* 低于 ThemeToggle 的 9999 */
    max-width: 280px;
    padding: 16px 18px 14px;
    color: #FFFFFF;
    font-family: var(--font-body, system-ui, sans-serif);
    font-size: 13px;
    line-height: 1.55;
    background: rgba(26, 22, 37, 0.92);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1.5px solid rgba(200, 75, 124, 0.55);
    border-radius: 14px;
    box-shadow:
      0 12px 32px rgba(0, 0, 0, 0.45),
      0 0 0 1px rgba(212, 168, 83, 0.15) inset;
    opacity: 0;
    transform: translateY(8px) scale(0.97);
    pointer-events: none;
    transition:
      opacity 0.28s ease,
      transform 0.28s cubic-bezier(0.34, 1.32, 0.64, 1);
  }
  .sakura-hint[data-show="true"] {
    opacity: 1;
    transform: translateY(0) scale(1);
    pointer-events: auto;
  }
  .sakura-hint[data-leaving="true"] {
    opacity: 0;
    transform: translateY(8px) scale(0.97);
    pointer-events: none;
  }

  /* 箭头（指向左下角的 ThemeToggle） */
  .sakura-hint::after {
    content: "";
    position: absolute;
    bottom: -8px;
    left: 32px;
    width: 14px;
    height: 14px;
    background: rgba(26, 22, 37, 0.92);
    border-right: 1.5px solid rgba(200, 75, 124, 0.55);
    border-bottom: 1.5px solid rgba(200, 75, 124, 0.55);
    transform: rotate(45deg);
  }

  .sakura-hint__title {
    margin: 0 0 6px;
    font-family: var(--font-display, "Noto Serif SC", serif);
    font-size: 15px;
    font-weight: 700;
    color: #D4A853;
    letter-spacing: 0.01em;
  }
  .sakura-hint__title-icon {
    margin-right: 4px;
  }
  .sakura-hint__body {
    margin: 0 0 12px;
    color: rgba(255, 255, 255, 0.92);
  }
  .sakura-hint__actions {
    display: flex;
    gap: 8px;
    align-items: center;
    justify-content: flex-end;
  }
  .sakura-hint__btn {
    appearance: none;
    border: none;
    border-radius: 999px;
    padding: 6px 14px;
    font-family: inherit;
    font-size: 12.5px;
    font-weight: 700;
    cursor: pointer;
    transition: transform 0.15s ease, filter 0.15s ease, background 0.15s ease;
  }
  .sakura-hint__btn--primary {
    color: #FFFFFF;
    background: linear-gradient(135deg, #C84B7C 0%, #E5578B 100%);
    box-shadow: 0 2px 8px rgba(200, 75, 124, 0.45);
  }
  .sakura-hint__btn--primary:hover {
    transform: translateY(-1px);
    filter: brightness(1.08);
  }
  .sakura-hint__btn--ghost {
    color: rgba(255, 255, 255, 0.78);
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.18);
  }
  .sakura-hint__btn--ghost:hover {
    color: #FFFFFF;
    background: rgba(255, 255, 255, 0.14);
  }
  .sakura-hint__btn:focus-visible {
    outline: 2px solid #D4A853;
    outline-offset: 2px;
  }
  .sakura-hint__close {
    position: absolute;
    top: 6px;
    right: 8px;
    width: 22px;
    height: 22px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: none;
    border-radius: 999px;
    color: rgba(255, 255, 255, 0.65);
    background: transparent;
    font-size: 14px;
    line-height: 1;
    cursor: pointer;
    transition: color 0.15s ease, background 0.15s ease;
  }
  .sakura-hint__close:hover {
    color: #FFFFFF;
    background: rgba(255, 255, 255, 0.1);
  }
  .sakura-hint__close:focus-visible {
    outline: 2px solid #D4A853;
    outline-offset: 1px;
  }

  /* sakura 模式下隐藏（已是 sakura 用户不再提示，纯保险） */
  html.sakura .sakura-hint {
    display: none !important;
  }

  /* 移动端：底部居中 */
  @media (max-width: 640px) {
    .sakura-hint {
      bottom: 68px;
      left: 12px;
      right: 12px;
      max-width: none;
    }
    .sakura-hint::after {
      left: 24px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .sakura-hint { transition: opacity 0.01s linear; transform: none !important; }
    .sakura-hint[data-show="true"] { transform: none !important; }
    .sakura-hint[data-leaving="true"] { transform: none !important; }
  }
</style>

<div
  class="sakura-hint"
  id="sakura-hint"
  role="dialog"
  aria-labelledby="sakura-hint-title"
  aria-describedby="sakura-hint-body"
  data-show="false"
  hidden
>
  <button
    type="button"
    class="sakura-hint__close"
    id="sakura-hint-close"
    aria-label="关闭提示"
  >×</button>
  <p class="sakura-hint__title" id="sakura-hint-title">
    <span class="sakura-hint__title-icon" aria-hidden="true">✨</span>试试樱花主题
  </p>
  <p class="sakura-hint__body" id="sakura-hint-body">
    浅色 + 乐园手账配色，<br />适合白天阅读和血检记录。
  </p>
  <div class="sakura-hint__actions">
    <button type="button" class="sakura-hint__btn sakura-hint__btn--ghost" id="sakura-hint-later">稍后</button>
    <button type="button" class="sakura-hint__btn sakura-hint__btn--primary" id="sakura-hint-try">体验</button>
  </div>
</div>

<script is:inline>
  (function () {
    var DISMISS_KEY = "sakura-hint-dismissed-v1";
    var THEME_KEY = "sakura-theme";
    var SHOW_DELAY_MS = 5000;
    var AUTO_HIDE_MS = 30000;

    function read(key) {
      try { return localStorage.getItem(key); } catch (e) { return null; }
    }
    function write(key, val) {
      try { localStorage.setItem(key, val); } catch (e) {}
    }

    function init() {
      var hint = document.getElementById("sakura-hint");
      if (!hint) return;

      // 不显示条件：已 dismissed / 已是 sakura 用户 / sakura class 已挂上
      if (read(DISMISS_KEY) === "true") return;
      if (read(THEME_KEY) === "on") return;
      if (document.documentElement.classList.contains("sakura")) return;

      var laterBtn = document.getElementById("sakura-hint-later");
      var tryBtn = document.getElementById("sakura-hint-try");
      var closeBtn = document.getElementById("sakura-hint-close");

      var autoHideTimer = null;
      var leaveTimer = null;
      var shown = false;

      function dismiss(persist) {
        if (!shown) return;
        if (persist) write(DISMISS_KEY, "true");
        if (autoHideTimer) { clearTimeout(autoHideTimer); autoHideTimer = null; }
        hint.setAttribute("data-show", "false");
        hint.setAttribute("data-leaving", "true");
        leaveTimer = setTimeout(function () {
          hint.hidden = true;
          document.removeEventListener("keydown", onKey, true);
          document.removeEventListener("click", onOutside, true);
        }, 300);
        shown = false;
      }

      function onKey(e) {
        if (e.key === "Escape" || e.key === "Esc") {
          dismiss(true);
        }
      }
      function onOutside(e) {
        if (!shown) return;
        var t = e.target;
        // 点 toggle 自身不当作外部点击（避免冲突）
        var toggle = document.getElementById("sakura-toggle");
        if (toggle && (t === toggle || toggle.contains(t))) return;
        if (hint.contains(t)) return;
        dismiss(true);
      }

      function show() {
        if (read(DISMISS_KEY) === "true") return;
        if (read(THEME_KEY) === "on") return;
        if (document.documentElement.classList.contains("sakura")) return;

        hint.hidden = false;
        // 强制 reflow 让初始 opacity:0 transform 生效
        // eslint-disable-next-line no-unused-expressions
        hint.offsetWidth;
        hint.setAttribute("data-show", "true");
        hint.removeAttribute("data-leaving");
        shown = true;

        document.addEventListener("keydown", onKey, true);
        // 用 click 而非 mousedown，避免与按钮 click 冲突
        document.addEventListener("click", onOutside, true);

        // 30s 自动淡出（不持久化 dismiss）
        autoHideTimer = setTimeout(function () {
          dismiss(false);
        }, AUTO_HIDE_MS);
      }

      laterBtn && laterBtn.addEventListener("click", function (e) {
        e.stopPropagation();
        dismiss(true);
      });
      closeBtn && closeBtn.addEventListener("click", function (e) {
        e.stopPropagation();
        dismiss(true);
      });
      tryBtn && tryBtn.addEventListener("click", function (e) {
        e.stopPropagation();
        // 通知 ThemeToggle 切到 sakura
        try {
          document.dispatchEvent(new CustomEvent("sakura-hint:activate"));
        } catch (err) {}
        dismiss(true);
      });

      // 用户已经主动开了 sakura（比如直接点 toggle）后，立即清掉提示
      document.addEventListener("sakura-theme:change", function (e) {
        if (e && e.detail && e.detail.on) {
          dismiss(true);
        }
      });

      // 延迟显示
      var startTimer = setTimeout(show, SHOW_DELAY_MS);
      // 页面卸载前清理
      window.addEventListener("pagehide", function () {
        if (startTimer) clearTimeout(startTimer);
        if (autoHideTimer) clearTimeout(autoHideTimer);
        if (leaveTimer) clearTimeout(leaveTimer);
      }, { once: true });
    }

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", init);
    } else {
      init();
    }
  })();
</script>
