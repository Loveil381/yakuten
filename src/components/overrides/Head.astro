---
/**
 * Head override — extends Starlight's default Head with:
 * - Vercel Analytics & Speed Insights
 * - hreflang alternate links (HTML head, complements sitemap hreflang)
 * - x-default hreflang for language negotiation
 */
import Default from '@astrojs/starlight/components/Head.astro';
import Analytics from '@vercel/analytics/astro';
import SpeedInsights from '@vercel/speed-insights/astro';
import ThemeToggle from '../ThemeToggle.astro';

const pathname = Astro.url.pathname;
const site = 'https://hrtyaku.com';

// Per-page authority signals for E-E-A-T (crawler-readable meta)
const route = Astro.locals.starlightRoute;
const entryData: Record<string, unknown> = (route?.entry?.data as Record<string, unknown>) ?? {};
const pageLastReviewed = entryData.lastReviewed
  ? new Date(entryData.lastReviewed as string | Date).toISOString()
  : null;
const pageEvidenceLevel = (entryData.evidenceLevel as string) ?? null;
const pageRefCount = Array.isArray(entryData.references) ? (entryData.references as string[]).length : 0;
const pageMedicalReviewer = (entryData.medicalReviewer as string) ?? 'HRT药典 Editorial Team';

// Per-page OG image URL (generated postbuild into dist/og/<locale>/<path>.png).
// Strip leading/trailing slash, drop locale segment if present (we want parts after /{locale}/).
const ogPathParts = pathname.replace(/^\//, '').replace(/\/$/, '').split('/');
const ogPageUrl = ogPathParts.length > 0
  ? `${site}/og/${ogPathParts.join('/')}.png`
  : `${site}/og-image.svg`;
// Fallback to global SVG if page isn't a content page (e.g., tool routes).
const perPageOgImage = ogPageUrl;

// Build hreflang alternates from current pathname
// Pattern: /{locale}/rest/of/path/ → extract locale, build alternates
const localeMap = [
  { code: 'zh-CN', prefix: '/zh/' },
  { code: 'en', prefix: '/en/' },
  { code: 'ja', prefix: '/ja/' },
  { code: 'ko', prefix: '/ko/' },
] as const;

// Extract the locale-independent path segment
let pagePath = '';
for (const { prefix } of localeMap) {
  if (pathname.startsWith(prefix)) {
    pagePath = pathname.slice(prefix.length);
    break;
  }
}

// Build alternate URLs
const alternates = localeMap.map(({ code, prefix }) => ({
  hreflang: code,
  href: `${site}${prefix}${pagePath}`,
}));

// x-default points to the default locale (zh)
const xDefault = `${site}/zh/${pagePath}`;

// Detect current locale for og:locale
const ogLocaleMap: Record<string, string> = { '/zh/': 'zh_CN', '/en/': 'en_US', '/ja/': 'ja_JP', '/ko/': 'ko_KR' };
const currentOgLocale = Object.entries(ogLocaleMap).find(([p]) => pathname.startsWith(p))?.[1] ?? 'zh_CN';
const alternateOgLocales = Object.values(ogLocaleMap).filter((l) => l !== currentOgLocale);
---

<Default {...Astro.props}><slot /></Default>
<link rel="manifest" href="/manifest.json" />
<link rel="alternate" hreflang="x-default" href={xDefault} />
<meta property="og:locale" content={currentOgLocale} />
{alternateOgLocales.map((loc) => (
  <meta property="og:locale:alternate" content={loc} />
))}
{pageLastReviewed && (
  <>
    <meta property="article:modified_time" content={pageLastReviewed} />
    <meta property="og:updated_time" content={pageLastReviewed} />
    <meta name="last-reviewed" content={pageLastReviewed.split('T')[0]} />
  </>
)}
{pageEvidenceLevel && <meta name="evidence-level" content={pageEvidenceLevel} />}
{pageRefCount > 0 && <meta name="citation-count" content={String(pageRefCount)} />}
<meta name="medical-reviewer" content={pageMedicalReviewer} />
{/* Per-page OG image override (falls back to global og-image.svg set in astro.config.mjs). */}
{pageLastReviewed && (
  <>
    <meta property="og:image" content={perPageOgImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:type" content="image/png" />
    <meta name="twitter:image" content={perPageOgImage} />
    <meta name="twitter:card" content="summary_large_image" />
  </>
)}
<ThemeToggle />
<script is:inline>
  // Dev-mode opt-out for Vercel Analytics & Speed Insights.
  // Run `localStorage.setItem('yakuten-dev','1')` once in any browser you use
  // for testing; all subsequent pageviews/vitals from that browser are dropped.
  // Remove with `localStorage.removeItem('yakuten-dev')`.
  (function () {
    try {
      if (localStorage.getItem('yakuten-dev') === '1') {
        var drop = function () { return null; };
        window.webAnalyticsBeforeSend = drop;
        window.speedInsightsBeforeSend = drop;
      }
    } catch (_) { /* private mode etc. */ }
  })();
</script>
<Analytics />
<SpeedInsights />
<script>
  if ('serviceWorker' in navigator) {
    navigator.serviceWorker.register('/sw.js').catch(() => {});
  }
</script>
