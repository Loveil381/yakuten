---
/**
 * EmergencyBanner (sakura) — 用的是 src/i18n/ui.ts 里原 banner 的同一份翻译
 * 文本和旧版逐字一致，只改外观
 */
import { t, type Locale } from '../../i18n/ui';

interface Props {
  locale?: string;
}
const { locale = 'zh' } = Astro.props;
const loc = (locale in { zh: 1, en: 1, ja: 1, ko: 1 } ? locale : 'zh') as Locale;

const linkHref = `/sakura/${loc}/risks/`;
const heading = t(loc, 'emergency.text');
const symptoms = t(loc, 'emergency.symptoms');
const cta = t(loc, 'emergency.link');
---

<div class="sakura-emergency" role="alert" aria-live="assertive">
  <div class="sakura-emergency__inner">
    <strong class="sakura-emergency__heading">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z" />
        <line x1="12" y1="9" x2="12" y2="13" />
        <line x1="12" y1="17" x2="12.01" y2="17" />
      </svg>
      {heading}
    </strong>
    <span class="sakura-emergency__symptoms">{symptoms}</span>
    <a href={linkHref} class="sakura-emergency__cta">{cta}</a>
  </div>
</div>

<style>
  .sakura-emergency {
    background: repeating-linear-gradient(
      45deg,
      #E5578B 0 16px,
      #E65D4A 16px 32px
    );
    color: #fff;
    padding: 10px 24px;
    border-bottom: 2px solid #4A2838;
    text-shadow: 1.5px 1.5px 0 #4A2838;
    font-family: "Noto Sans SC", system-ui, sans-serif;
  }
  .sakura-emergency__inner {
    max-width: 80rem;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    text-align: center;
  }
  .sakura-emergency__heading {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-weight: 700;
    font-size: 14px;
  }
  .sakura-emergency__symptoms {
    font-size: 13px;
    font-weight: 500;
    opacity: 0.95;
    line-height: 1.55;
    max-width: 64rem;
  }
  .sakura-emergency__cta {
    display: inline-flex;
    margin-top: 4px;
    padding: 4px 14px;
    font-size: 12px;
    font-weight: 700;
    color: #4A2838;
    background: #FFFAF0;
    border: 2px solid #4A2838;
    border-radius: 999px;
    box-shadow: 2px 2px 0 #4A2838;
    text-decoration: none;
    transition: transform .15s, box-shadow .15s;
  }
  .sakura-emergency__cta:hover {
    transform: translate(-1px, -1px);
    box-shadow: 3px 3px 0 #4A2838;
  }
</style>
