---
/**
 * SiteFooter (sakura) — 新版底栏
 * 全部文字来自 src/i18n/ui.ts，和旧版 SiteFooter 共享
 */
import HibiscusMark from './HibiscusMark.astro';
import { t, type Locale } from '../../i18n/ui';

interface Props {
  locale?: string;
}
const { locale = 'zh' } = Astro.props;
const loc = (locale in { zh: 1, en: 1, ja: 1, ko: 1 } ? locale : 'zh') as Locale;

const brand = t(loc, 'footer.brand');
const notice = t(loc, 'footer.notice');
const copy = t(loc, 'footer.copy');
const disclaimerLabel = t(loc, 'footer.link.disclaimer');
const guidesLabel = t(loc, 'footer.link.guides');
const githubLabel = t(loc, 'footer.link.github');
const feedbackLabel = t(loc, 'footer.link.feedback');
const navLabel = t(loc, 'footer.navLabel');
---

<footer class="sakura-footer">
  <div class="sakura-footer__inner">
    <div class="sakura-footer__brand-row">
      <HibiscusMark size={32} />
      <span class="sakura-footer__brand-name">{brand}</span>
    </div>
    <p class="sakura-footer__notice">{notice}</p>
    <nav class="sakura-footer__nav" aria-label={navLabel}>
      <a href={`/sakura/${loc}/about/`}>{disclaimerLabel}</a>
      <span aria-hidden="true">·</span>
      <a href={`/sakura/${loc}/guides/`}>{guidesLabel}</a>
      <span aria-hidden="true">·</span>
      <a href="https://github.com/cantascendia/yakuten" target="_blank" rel="noopener noreferrer">{githubLabel}</a>
      <span aria-hidden="true">·</span>
      <a href="https://wj.qq.com/s2/16576000/5fe5/" target="_blank" rel="noopener noreferrer">{feedbackLabel}</a>
    </nav>
    <p class="sakura-footer__copy">© 2026 · {copy}</p>
  </div>
</footer>

<style>
  .sakura-footer {
    margin-top: 64px;
    padding: 32px 24px 28px;
    background: #FFD4E0;
    border-top: 2px solid #4A2838;
  }
  .sakura-footer__inner {
    max-width: 1280px;
    margin: 0 auto;
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: 10px;
    align-items: center;
  }
  .sakura-footer__brand-row {
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .sakura-footer__brand-name {
    background: linear-gradient(135deg, #E5578B, #FF8E7F 50%, #F5C842);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    font-family: "Fraunces", "Noto Serif SC", serif;
    font-size: 20px;
    font-weight: 600;
  }
  .sakura-footer__notice {
    font-size: 13px;
    color: #4A2838;
    margin: 0;
  }
  .sakura-footer__nav {
    display: flex;
    gap: 10px;
    font-size: 12px;
    flex-wrap: wrap;
    justify-content: center;
  }
  .sakura-footer__nav a {
    color: #E5578B;
    text-decoration: none;
    font-weight: 600;
  }
  .sakura-footer__nav a:hover {
    text-decoration: underline;
  }
  .sakura-footer__nav span {
    color: #7A5568;
  }
  .sakura-footer__copy {
    margin: 8px 0 0;
    font-size: 11px;
    color: #7A5568;
    letter-spacing: 0.03em;
  }
</style>
