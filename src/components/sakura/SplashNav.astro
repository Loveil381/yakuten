---
/**
 * SplashNav (sakura) — 新版顶栏
 * 所有文字走 i18n/ui.ts，和旧版 nav 用同一份翻译
 * 不引入任何设计稿里的"绯英/YAKUTEN"等虚构品牌字
 */
import HibiscusMark from './HibiscusMark.astro';
import { t, type Locale } from '../../i18n/ui';

interface Props {
  locale?: string;
  currentPath?: string;
}
const { locale = 'zh', currentPath = '' } = Astro.props;
const loc = (locale in { zh: 1, en: 1, ja: 1, ko: 1 } ? locale : 'zh') as Locale;

const links: Array<[string, string]> = [
  [`/sakura/${loc}/`,                    t(loc, 'hero.title')],
  [`/sakura/${loc}/pathway/`,            t(loc, 'nav.pathway')],
  [`/sakura/${loc}/medications/estrogens/oral/`, t(loc, 'nav.medications')],
  [`/sakura/${loc}/blood-tests/`,        t(loc, 'nav.bloodTests')],
  [`/sakura/${loc}/risks/`,              t(loc, 'nav.risks')],
];

const allLocales: Array<[string, string]> = [
  ['zh', '中文'],
  ['en', 'EN'],
  ['ja', '日本語'],
  ['ko', '한국어'],
];

const ariaLabel = t(loc, 'nav.ariaLabel');
---

<nav class="sakura-nav" aria-label={ariaLabel}>
  <a href={`/sakura/${loc}/`} class="sakura-nav__brand">
    <HibiscusMark size={40} />
    <span class="sakura-nav__name">
      HRT<span class="gradient-flame">药典</span>
    </span>
  </a>

  <div class="sakura-nav__links">
    {links.map(([href, label], idx) => {
      const isHome = idx === 0;
      const active = isHome
        ? currentPath === href
        : currentPath.startsWith(href.replace(/\/$/, ''));
      return (
        <a
          href={href}
          class:list={['sakura-nav__link', active && 'sakura-nav__link--active']}
        >
          {label}
        </a>
      );
    })}
  </div>

  <div class="sakura-nav__locales">
    {allLocales.map(([code, label]) => (
      <a
        href={`/sakura/${code}/`}
        class:list={['sakura-nav__locale', code === loc && 'sakura-nav__locale--active']}
      >
        {label}
      </a>
    ))}
  </div>
</nav>

<style>
  .sakura-nav {
    position: sticky;
    top: 0;
    z-index: 50;
    background: #FFF5E0;
    border-bottom: 2px solid #4A2838;
    padding: 12px 32px;
    display: flex;
    align-items: center;
    gap: 16px;
    box-shadow: 0 3px 0 #FFD4E0;
    flex-wrap: wrap;
  }
  .sakura-nav__brand {
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    color: inherit;
  }
  .sakura-nav__name {
    font-family: "Fraunces", "Noto Serif SC", serif;
    font-size: 20px;
    color: #4A2838;
    line-height: 1;
  }
  .gradient-flame {
    background: linear-gradient(135deg, #E5578B, #FF8E7F 50%, #F5C842);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .sakura-nav__links {
    display: flex;
    gap: 6px;
    margin-left: 12px;
    flex: 1;
    flex-wrap: wrap;
  }
  .sakura-nav__link {
    padding: 7px 14px;
    color: #4A2838;
    border: 2px solid transparent;
    border-radius: 999px;
    font-family: "Noto Sans SC", sans-serif;
    font-size: 13px;
    font-weight: 700;
    text-decoration: none;
    transition: all 0.15s;
  }
  .sakura-nav__link:hover {
    background: #FFD4E0;
  }
  .sakura-nav__link--active {
    background: #FFA8C5;
    color: #fff;
    border-color: #4A2838;
    box-shadow: 3px 3px 0 #4A2838;
    transform: translate(-1px, -1px);
  }
  .sakura-nav__locales {
    display: flex;
    gap: 4px;
    font-size: 11px;
    font-weight: 700;
  }
  .sakura-nav__locale {
    padding: 4px 8px;
    color: #7A5568;
    text-decoration: none;
    border-radius: 6px;
    font-family: "Noto Sans SC", sans-serif;
  }
  .sakura-nav__locale--active {
    color: #E5578B;
    background: #FFD4E0;
  }

  @media (max-width: 860px) {
    .sakura-nav__links {
      order: 3;
      width: 100%;
      margin-left: 0;
    }
  }
</style>
