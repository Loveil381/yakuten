---
/**
 * ThemeToggle — 同页切换 html.sakura class
 *
 * 不跳转路由。点击 = 当前页用 sakura 视觉重绘。
 * Starlight 的侧栏/搜索/TOC/面包屑/分页全部保留。
 * 偏好存 localStorage，跨页保持。
 *
 * 配套：SakuraHint 首次访问引导卡片（同 layout 渲染）。
 *  · ThemeToggle 监听 `sakura-hint:activate` 自定义事件 → 切到 sakura
 *  · ThemeToggle 切换时派发 `sakura-theme:change` 让 hint 等组件感知
 */
---

<style is:global>
  /* 屏幕阅读器专用描述：visually hidden 但仍参与 a11y 树 */
  .sakura-toggle-sr-only {
    position: absolute !important;
    width: 1px !important;
    height: 1px !important;
    padding: 0 !important;
    margin: -1px !important;
    overflow: hidden !important;
    clip: rect(0, 0, 0, 0) !important;
    white-space: nowrap !important;
    border: 0 !important;
  }

  #sakura-toggle {
    position: fixed;
    bottom: 24px;
    left: 24px;
    z-index: 9999;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 9px 16px;
    font-family: var(--font-body, system-ui, sans-serif);
    font-size: 13px;
    font-weight: 700;
    /* 纯白文字，在所有深色/粉色背景上都够对比度 */
    color: #FFFFFF;
    /* 实心樱粉渐变，不再透明毛玻璃 */
    background: linear-gradient(135deg, #C84B7C 0%, #E5578B 100%);
    border: 1.5px solid rgba(255, 255, 255, 0.35);
    border-radius: 999px;
    cursor: pointer;
    transition: transform 0.15s ease, filter 0.15s ease, box-shadow 0.2s ease;
    box-shadow: 0 3px 12px rgba(200, 75, 124, 0.45);
  }
  #sakura-toggle:hover {
    transform: translateY(-2px);
    filter: brightness(1.08);
    box-shadow: 0 6px 18px rgba(200, 75, 124, 0.6);
  }
  #sakura-toggle:active { transform: translateY(0); }
  #sakura-toggle:focus-visible {
    outline: 2px solid #FFFFFF;
    outline-offset: 2px;
    box-shadow: 0 0 0 4px rgba(200, 75, 124, 0.5);
  }

  #sakura-toggle .sakura-toggle__icon {
    font-size: 14px;
    line-height: 1;
    transition: transform 0.3s ease;
  }
  #sakura-toggle:hover .sakura-toggle__icon {
    transform: rotate(20deg) scale(1.1);
  }

  /* 副标签：默认隐藏，hover/focus 时滑入显示，提示「这是切换主题」 */
  #sakura-toggle .sakura-toggle__hint {
    max-width: 0;
    overflow: hidden;
    opacity: 0;
    white-space: nowrap;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.02em;
    transition: max-width 0.25s ease, opacity 0.2s ease, margin-left 0.25s ease;
    margin-left: 0;
  }
  #sakura-toggle:hover .sakura-toggle__hint,
  #sakura-toggle:focus-visible .sakura-toggle__hint {
    max-width: 120px;
    opacity: 0.95;
    margin-left: 4px;
  }

  /* 当 sakura 已开启：按钮变糖果胶囊 */
  html.sakura #sakura-toggle {
    background: #FFFAF0;
    color: #4A2838;
    border: 2px solid #4A2838;
    box-shadow: 3px 3px 0 #4A2838;
  }
  html.sakura #sakura-toggle:hover {
    transform: translate(-1px, -1px);
    box-shadow: 4px 4px 0 #4A2838;
    background: #FFE4EC;
  }
  html.sakura #sakura-toggle .sakura-toggle__label::after {
    content: " ✓";
    color: #E5578B;
    font-weight: 700;
  }

  @media (max-width: 640px) {
    #sakura-toggle {
      bottom: 16px; left: 16px;
      padding: 6px 12px; font-size: 12px;
    }
    /* 移动端不显示副标签节省空间 */
    #sakura-toggle .sakura-toggle__hint { display: none; }
  }
  @media (prefers-reduced-motion: reduce) {
    #sakura-toggle,
    #sakura-toggle .sakura-toggle__icon,
    #sakura-toggle .sakura-toggle__hint { transition: none; }
  }
</style>

<script is:inline>
  (function () {
    var KEY = "sakura-theme";
    var root = document.documentElement;

    // 进入页面立刻应用偏好（避免闪烁）
    try {
      if (localStorage.getItem(KEY) === "on") {
        root.classList.add("sakura");
      }
    } catch (e) {}

    // 文案：根据当前模式动态切换
    function copyFor(on) {
      // on = 当前是否已是 sakura
      if (on) {
        return {
          ariaLabel: "切回二相乐园主题（深色 · 米哈游风格）",
          title: "切回二相乐园主题（深色）— 当前为樱花手账浅色模式",
          srDesc: "当前为樱花手账浅色主题。点击切回米哈游二相乐园深色主题。皮肤偏好保存在你的浏览器，不会上传。",
          hint: "切回深色"
        };
      }
      return {
        ariaLabel: "切换到樱花手账主题（浅色 · 优化血检手账界面）",
        title: "切换乐园手账主题（樱粉浅色风格 · 优化血检手账界面） — 不会跳转路由，侧栏/搜索/TOC 全部保留",
        srDesc: "点击切换到樱花手账浅色主题，配色更柔和，并启用 v3.2 血检手账记录界面。皮肤偏好保存在你的浏览器，不会上传。",
        hint: "切换主题"
      };
    }

    function syncCopy(btn) {
      var on = root.classList.contains("sakura");
      var c = copyFor(on);
      btn.setAttribute("aria-label", c.ariaLabel);
      btn.setAttribute("title", c.title);
      btn.setAttribute("aria-pressed", on ? "true" : "false");
      var sr = btn.querySelector("#sakura-toggle-desc");
      if (sr) sr.textContent = c.srDesc;
      var hint = btn.querySelector(".sakura-toggle__hint");
      if (hint) hint.textContent = c.hint;
    }

    function setSakura(on) {
      if (on) {
        root.classList.add("sakura");
        try { localStorage.setItem(KEY, "on"); } catch (e) {}
      } else {
        root.classList.remove("sakura");
        try { localStorage.setItem(KEY, "off"); } catch (e) {}
      }
      var btn = document.getElementById("sakura-toggle");
      if (btn) syncCopy(btn);
      // 派发事件，让 SakuraHint 等组件感知
      try {
        document.dispatchEvent(new CustomEvent("sakura-theme:change", { detail: { on: on } }));
      } catch (e) {}
    }

    function mount() {
      if (document.getElementById("sakura-toggle")) return;
      var btn = document.createElement("button");
      btn.id = "sakura-toggle";
      btn.type = "button";
      btn.setAttribute("aria-describedby", "sakura-toggle-desc");
      btn.innerHTML =
        '<span class="sakura-toggle__icon" aria-hidden="true">🌸</span>' +
        '<span class="sakura-toggle__label">新版</span>' +
        '<span class="sakura-toggle__hint" aria-hidden="true">切换主题</span>' +
        '<span id="sakura-toggle-desc" class="sakura-toggle-sr-only"></span>';
      syncCopy(btn);
      btn.addEventListener("click", function () {
        var on = root.classList.contains("sakura");
        setSakura(!on);
      });
      document.body.appendChild(btn);

      // 监听来自 SakuraHint 的「体验」事件
      document.addEventListener("sakura-hint:activate", function () {
        setSakura(true);
      });
    }

    if (document.body) mount();
    else document.addEventListener("DOMContentLoaded", mount);
  })();
</script>
